rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profile Rules
    match /more_users/{userId} {
      // Allow read for any authenticated user (needed for username uniqueness check and friend search)
      allow read: if request.auth != null;
      
      // Allow create/update if:
      // 1. Authenticated user matches the document ID
      // 2. The user is setting their own data
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Comparison Request Rules
    match /comparison_requests/{reqId} {
      // Both parties can read the request
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.from || 
        request.auth.uid == resource.data.to
      );
      
      // Anyone logged in can create a request if they are the sender
      allow create: if request.auth != null && request.auth.uid == request.resource.data.from;
      
      // Update allowed:
      // 1. Recipient can change status (accept/decline)
      // 2. Sender can change status (unlikely but possible for cancellation if implemented via status)
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.to || 
        request.auth.uid == resource.data.from
      );
      
      // Both parties can delete a request
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.from || 
        request.auth.uid == resource.data.to
      );
    }
  }
}
